---
layout: base.njk
title: News and Announcements
eleventyExcludeFromCollections: true

---

<div
  class="hero"
  style="background: linear-gradient(135deg, var(--color-accent), #cb6b51);"
>
  <h2>Region 1 News</h2>
  <p>Latest updates, newsletters, and announcements from NATRC Region 1.</p>
</div>

<div class="content-grid">
  {%- for post in collections.news | reverse -%}
    <div class="card">
      <h3><a href="{{ post.url | url }}">{{ post.data.title }}</a></h3>
      <p style="color: var(--color-primary-dark); font-weight: 600; font-size: 0.9em; margin-bottom: 10px;">
        {{ post.date | dateFilter }}
      </p>
      <p>{{ post.data.summary }}</p>
      <a href="{{ post.url | url }}" class="btn btn-secondary">Read More</a>
    </div>
  {%- endfor -%}
</div>
