---
layout: base.njk
title: Write a New Story
---

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
<script type="importmap">
  {
    "imports": {
      "octokit": "https://cdn.skypack.dev/octokit"
    }
  }
</script>

<div class="admin-editor" x-data="cmsEditor()">
  <div class="hero" style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)); margin-bottom: 20px;">
    <h2>Create Your Story</h2>
    <p>Compose your article and submit it for review.</p>
  </div>

  <div class="editor-controls card" style="margin-bottom: 30px; display: flex; gap: 15px; flex-wrap: wrap; align-items: center; justify-content: space-between;">
    <div style="display: flex; gap: 10px; align-items: center;">
      <button @click="saveDraft" class="btn btn-secondary" :disabled="loading">
        <span x-show="!loading">Save Draft</span>
        <span x-show="loading">Working...</span>
      </button>
      <button @click="requestPublish" class="btn btn-primary" :disabled="loading">
        Request Publish
      </button>
      
      <!-- Resume Draft Selector -->
      <div x-show="availableDrafts.length > 0" style="margin-left: 15px; display: flex; align-items: center; gap: 10px;">
        <label for="draft-select" style="font-weight: 600; font-size: 0.9em;">Resume Draft:</label>
        <select id="draft-select" @change="loadDraft($event.target.value)" style="padding: 5px; border-radius: 4px; border: 1px solid #ddd;">
          <option value="">-- Select a draft --</option>
          <template x-for="draft in availableDrafts" :key="draft.name">
            <option :value="draft.name" x-text="draft.name.replace('draft/', '')"></option>
          </template>
        </select>
      </div>
    </div>
    <div style="display: flex; gap: 10px;">
        <button @click="saveDraft" class="btn btn-secondary" :disabled="loading">
            Edit Draft
        </button>
        <button @click="deleteDraft" class="btn btn-secondary" style="background-color: #fee2e2; color: #991b1b;" :disabled="loading">
            Delete Draft
        </button>
    </div>
  </div>

  <div class="card" style="margin-bottom: 30px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
      <div class="form-group">
        <label for="author-name" style="display: block; font-weight: 700; margin-bottom: 8px;">Your Name</label>
        <input type="text" id="author-name" x-model="authorName" placeholder="Enter your full name" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd;">
      </div>
      <div class="form-group">
        <label for="author-email" style="display: block; font-weight: 700; margin-bottom: 8px;">Email Address</label>
        <input type="email" id="author-email" x-model="authorEmail" placeholder="you@example.com" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd;">
      </div>
    </div>

    <div class="form-group" style="margin-bottom: 20px;">
      <label for="article-title" style="display: block; font-weight: 700; margin-bottom: 8px;">Article Title</label>
      <input type="text" id="article-title" x-model="articleTitle" placeholder="Enter a catchy title..." style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; font-size: 1.1rem;">
    </div>

    <div class="form-group" style="margin-bottom: 20px;">
      <label for="article-summary" style="display: block; font-weight: 700; margin-bottom: 8px;">Summary (Short preview)</label>
      <textarea id="article-summary" x-model="articleSummary" rows="2" placeholder="What is this story about?" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; font-family: inherit;"></textarea>
    </div>

    <div id="editor" style="height: 400px; background: white; border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;"></div>
  </div>

  <!-- Github Token Modal (Simple version) -->
  <div x-show="showAuth" class="modal-overlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;">
    <div class="card" style="max-width: 400px; width: 90%;">
      <h3>GitHub Authentication</h3>
      <p style="font-size: 0.9em; color: var(--color-text-muted); margin-bottom: 15px;">To save drafts and submit PRs, please enter a GitHub Personal Access Token (classic) with 'repo' scope.</p>
      <input type="password" x-model="token" placeholder="ghp_..." style="width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 4px;">
      <div style="display: flex; justify-content: flex-end; gap: 10px;">
        <button @click="showAuth = false" class="btn btn-secondary">Cancel</button>
        <button @click="saveToken" class="btn btn-primary">Save Token</button>
      </div>
    </div>
  </div>
</div>

<style>
  .ql-toolbar.ql-snow {
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    background: #f8f9fa;
    border-color: #ddd;
  }
  .ql-container.ql-snow {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    border-color: #ddd;
    font-family: var(--font-family);
    font-size: 1rem;
  }
  .admin-editor .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script src="{{ '/assets/js/cms.js' | url }}" type="module"></script>
