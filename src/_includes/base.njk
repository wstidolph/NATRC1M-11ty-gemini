<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("NATRC Region 1") }}</title>
    <meta
      name="description"
      content="{{ description | default('North American Trail Ride Conference Region 1: Competitive Trail Riding') }}"
    >
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Montserrat:wght@400;700;800&display=swap"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/national-theme.css' | url }}">
    <script>
      (function() {
        const urlParams = new URLSearchParams(window.location.search);
        const themeParam = urlParams.get('theme');
        if (themeParam) {
          localStorage.setItem('theme', themeParam);
        }
        const theme = localStorage.getItem('theme') || 'default';
        if (theme !== 'default') {
          document.documentElement.setAttribute('data-theme', theme);
        } else {
          document.documentElement.removeAttribute('data-theme');
        }

        // Update the browser title bar to show the selected theme at the beginning
        // This makes it easier to compare themes in multiple tabs, e.g., "social NATRC1M"
        const themePrefix = theme + ' NATRC1M';
        if (document.title.includes('NATRC Region 1')) {
          document.title = document.title.replace(/NATRC Region 1/g, themePrefix);
        } else if (!document.title.includes(themePrefix)) {
          document.title = themePrefix + ' - ' + document.title;
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      {% if page.url == "/" or page.url == "/index.html" %}
      <div class="header-utility-bar">
        <div class="container utility-container">
          <div class="utility-left">
            <span>NATRC Region 1 consists of Northern California, Oregon, Washington, Idaho, British Columbia, Alaska, and part of Nevada</span>
          </div>
          <div class="utility-right">
            <a href="https://www.facebook.com/groups/natrcregion1/" target="_blank" title="Follow us on Facebook">Facebook</a>
            <a href="/contact/" title="Contact Us">Contact</a>
          </div>
        </div>
      </div>
      {% endif %}
      <div class="container header-container">
        <h1 class="logo"><a href="{{ '/' | url }}">NATRC Region 1</a></h1>
        <button class="menu-toggle" aria-label="Toggle navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="main-nav">
          <ul>
            {%- for item in navigation %}
              <li>
                <a
                  href="{{ item.url | url }}"
                  {% if page.url == item.url %}
                    aria-current="page"
                  {% endif %}
                >{{ item.label }}</a>
              </li>
            {%- endfor %}
          </ul>
        </nav>
      </div>
    </header>

    <main class="site-main container">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-container">
        <div class="footer-left">
          <p>&copy; {% year %} NATRC Region 1. All rights reserved.</p>
        </div>
        <div class="footer-right theme-selection">
          <form class="theme-switcher">
            <span class="theme-label">Theme:</span>
            <div class="theme-options">
              <label class="theme-option">
                <input type="radio" name="theme-select" value="default">
                <span>Default</span>
              </label>
              <label class="theme-option">
                <input type="radio" name="theme-select" value="legacy">
                <span>Legacy</span>
              </label>
              <label class="theme-option">
                <input type="radio" name="theme-select" value="national">
                <span>National</span>
              </label>
              <label class="theme-option">
                <input type="radio" name="theme-select" value="social">
                <span>Social</span>
              </label>
            </div>
          </form>
        </div>
      </div>
    </footer>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.querySelector('.menu-toggle');
        const nav = document.querySelector('.main-nav');
        if(toggleBtn && nav) {
          toggleBtn.addEventListener('click', function() {
            this.classList.toggle('active');
            nav.classList.toggle('active');
          });
        }

        // Theme Switcher Logic
        const themeInputs = document.querySelectorAll('.theme-switcher input[name="theme-select"]');
        const currentTheme = localStorage.getItem('theme') || 'default';

        themeInputs.forEach(input => {
          if (input.value === currentTheme) {
            input.checked = true;
          }
          input.addEventListener('change', function() {
            const newTheme = this.value;
            localStorage.setItem('theme', newTheme);
            const url = new URL(window.location.href);
            url.searchParams.set('theme', newTheme);
            window.location.href = url.toString();
          });
        });
      });
    </script>
  </body>
</html>
